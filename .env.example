# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Sible Couture"

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Admin login: optional. If set, "username" on /admin/login becomes username@<domain>.
# Otherwise admins must sign in with their full Supabase email.
NEXT_PUBLIC_ADMIN_EMAIL_DOMAIN=yourdomain.com

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/asa_ecommerce

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# SendGrid
SENDGRID_API_KEY=SG.placeholder
SENDGRID_FROM_EMAIL=orders@siblecouture.com

# Analytics
NEXT_PUBLIC_FB_PIXEL_ID=your_pixel_id
NEXT_PUBLIC_TIKTOK_PIXEL_ID=your_tiktok_pixel_id

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Currency API (optional)
EXCHANGE_RATE_API_KEY=your_api_key
